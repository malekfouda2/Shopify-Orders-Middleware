modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
DEFAULT_DELIVERY_OFFSET_DAYS = "1"
DEFAULT_HOUSE_NUMBER = "0"
ENABLE_INVOICE_SYNC = "false"
LOG_LEVEL = "info"
ADMIN_USERNAME = "admin"
